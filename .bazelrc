# Import local settings generated by flake.nix shellHook
try-import %workspace%/.bazelrc.user

# --- Standard Compiler Rules ---
build --cxxopt=-std=c++23
build --host_cxxopt=-std=c++23

# Disable layering_check to avoid issues with standard headers under toolchains_llvm
build --features=-layering_check
build --host_features=-layering_check

# --- Linux Local Configurations ---
build:linux --action_env=PATH
build:linux --sandbox_add_mount_pair=/nix/store

# --- macOS Local Configurations ---
build:macos --strategy=CppCompile=local
build:macos --strategy=CppLink=local

# --- Buildbarn / Remote Execution (RBE) Configuration ---
# To build with Buildbarn: bazel build --config=remote <target>
build:remote --remote_executor=grpc://mac-brightstar:8980
build:remote --remote_cache=grpc://mac-brightstar:8980
build:remote --remote_timeout=3600
build:remote --remote_upload_local_results=true
build:remote --remote_download_outputs=toplevel
build:remote --spawn_strategy=remote,worker,sandboxed,local
build:remote --extra_execution_platforms=//:rbe_linux_x86_64
build:remote --extra_toolchains=@llvm_toolchain//:all
