{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug C++ (hello)",
            "type": "lldb",
            "request": "launch",
            "program": "${workspaceFolder}/.debug/hello",
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "bazel-build-dbg-cpp-hello",
            "sourceMap": {
                "/proc/self/cwd": "${workspaceFolder}"
            },
            "initCommands": [
                "command source ${workspaceFolder}/.debug/source-map.lldb"
            ]
        },
        {
            "name": "Debug Rust (hello_rust)",
            "type": "lldb",
            "request": "launch",
            "program": "${workspaceFolder}/.debug/hello_rust",
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "bazel-build-dbg-rust-hello",
            "sourceMap": {
                "/proc/self/cwd": "${workspaceFolder}"
            },
            "initCommands": [
                "command source ${workspaceFolder}/.debug/source-map.lldb"
            ]
        },
        {
            "name": "Debug Bazel Target (pick)",
            "type": "lldb",
            "request": "launch",
            "program": "${workspaceFolder}/.debug/current",
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "bazel-build-dbg-pick",
            "sourceMap": {
                "/proc/self/cwd": "${workspaceFolder}"
            },
            "initCommands": [
                "command source ${workspaceFolder}/.debug/source-map.lldb"
            ]
        },
        {
            "name": "Debug Go (hello_go)",
            "type": "go",
            "request": "launch",
            "mode": "exec",
            "program": "${workspaceFolder}/.debug/hello_go",
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "bazel-build-dbg-go-hello"
        }
    ]
}
